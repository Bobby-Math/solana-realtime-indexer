# Bind address for the API server
BIND_ADDRESS=127.0.0.1:8080

# RPC endpoints for backup/failover
RPC_ENDPOINTS=https://api.devnet.solana.com,https://rpc.ankr.com/solana_devnet

# ------------------------------------------
# PERFORMANCE TUNING
# ------------------------------------------
# Geyser channel capacity (events buffer before backpressure)
# Higher values = more memory usage, better burst handling
# Default: 1000 (was 8 - severe bottleneck)
GEYSER_CHANNEL_CAPACITY=1000

# Batch processing settings
# Higher values = fewer, larger database writes
# Default: 500 events per batch (was 2 - severe bottleneck)
BATCH_SIZE=500

# Maximum time to wait before flushing a batch (milliseconds)
# Default: 100ms (was 10ms - too aggressive)
BATCH_FLUSH_MS=100

# Database connection pool size
# Default: 20 connections (was 5 - limits concurrent writes)
DB_POOL_MAX_CONNECTIONS=20

# ------------------------------------------
# GEYSER CONFIGURATION
# ------------------------------------------
# Geyser endpoint - Use your Helius Geyser endpoint here
# Leave unset or set to mock://local-geyser for simulated data mode
GEYSER_ENDPOINT=https://your-helius-geyser-endpoint.com

# Geyser API key (from Helius)
GEYSER_API_KEY=your-api-key-here

# Geyser subscription filters
# Subscribe to specific programs (comma-separated)
GEYSER_PROGRAM_FILTERS=amm-program,token-program

# Subscribe to specific accounts (comma-separated)
GEYSER_ACCOUNT_FILTERS=

# Include slot updates (true/false)
GEYSER_INCLUDE_SLOTS=true

# Limit run duration to save Helius credits (seconds, 0 = unlimited)
# Recommended for testing: 15-30 seconds
# Production: Set to 0 for 24/7 operation
GEYSER_RUN_DURATION_SECONDS=0

# ------------------------------------------
# WAL CONFIGURATION
# ------------------------------------------
# Write-Ahead Log path for durability and crash recovery
# MUST be a fixed path (no timestamps) to persist across restarts
# Default: ./data/wal/geyser-main
# WARNING: Using timestamped paths will abandon unprocessed data on restart
WAL_PATH=./data/wal/geyser-main

# Clear WAL on startup (useful for testing/development)
# Set to 'true' to start with a fresh WAL on each restart
# Set to 'false' (default) to preserve WAL across restarts for crash recovery
# WARNING: Setting to 'true' in production will lose unprocessed data on restart!
# Development/testing: true
# Production: false
CLEAR_WAL_ON_STARTUP=false

# WAL durability mode (controls when data is fsynced to disk)
# strict: fsync after every write (true WAL semantics, no data loss on power failure)
# relaxed: fsync every 100ms in background (faster, but up to 100ms can be lost)
# Default: relaxed
# Production with strict durability requirements: strict
# Production throughput-focused: relaxed
WAL_DURABILITY_MODE=relaxed

# WAL garbage collection safety margin (number of entries to keep as buffer)
# Prevents race condition between consumer reads and GC deletes
# Higher values = more disk space used, but safer
# Minimum: 100, Default: 1000
# Tradeoff: ~1KB per entry, so default 1000 = ~1MB additional storage
# Production: 1000 (recommended) or higher for extra safety
# Development/testing: 100 (to save disk space)
WAL_GC_SAFETY_MARGIN=1000

# ------------------------------------------
# DATABASE CONFIGURATION
# ------------------------------------------
# Database connection (optional - uses dry-run mode if not set)
DATABASE_URL=postgresql://solana:solana@localhost:5432/solana_pipeline

# Data retention policy - how long to keep data in memory before pruning
# Only affects the in-memory store (not TimescaleDB, which keeps all data)
# Higher values = more memory usage, longer historical query windows
# Default: 3600 seconds (1 hour)
# Recommended: 3600-7200 for production (1-2 hours)
# Development/testing: 300-600 (5-10 minutes) to save memory
RETENTION_MAX_AGE_SECS=3600

# ------------------------------------------
# LOGGING
# ------------------------------------------
# Log level (debug,info,warn,error)
LOG_LEVEL=info